# ─── FanFundingSui — Environment Variables ───
# Fill in values after deploying the Sui Move contract.

# ─── Sui (client-visible) ───
# The Package ID from `sui client publish` output
NEXT_PUBLIC_PACKAGE_ID=

# The Collection shared object ID from `init_collection` call
NEXT_PUBLIC_COLLECTION_ID=

# Sui fullnode RPC URL (testnet)
NEXT_PUBLIC_SUI_NODE_URL=https://fullnode.testnet.sui.io:443

# zkLogin (Google)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# zkLogin prover endpoint (Mysten hosted or your own)
ZKLOGIN_PROVER_URL=https://prover.testnet.sui.io/v1

# ─── Pinata / IPFS ───
# Server-side JWT (used by /api/pinata/upload — never exposed to browser)
PINATA_JWT=your_pinata_jwt_here

# Client-side JWT (only if uploading directly from browser via src/lib/ipfs.ts)
NEXT_PUBLIC_PINATA_JWT=
